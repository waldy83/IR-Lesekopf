>D 48
; --- EINSTELLUNGEN --- 3.6
factor=100
zaehler_start=3686476
chart_type_30min=1
chart_type_day=0
chart_type_month=0

; --- INTERNE VARIABLEN ---
res=0
save=0
tmp=0
hour=0
yr=0
da=1
GasTotal=0
utm="00d 00h 00m"
M:p:dcon=0 31
M:p:mcon=0 12
M:p:g30=0 48
p:mval=0
p:dval=0
p:yval=0
m30=0
last_gas=0
avg_g=0
v_mod=1
; Schutz-Variable: Der Name muss mit "w" beginnen
nm="waldy-smarthome.de"

>B
=>sensor53 r
is(0 "Jan|Feb|Mär|Apr|Mai|Jun|Jul|Aug|Sep|Okt|Nov|Dez|")
smlj=0
; Wir setzen den internen SML-Counter auf 0, um sauber im Script zu rechnen
=>sensor53 c1 0
last_gas=0
GasTotal=zaehler_start

#30min
if wm>0
then
wcs <div id="chart30" style="width:400px;"></div>
wcs <script language="JavaScript">function draw30(){
if (chart_type_30min==0)
then
wcs var data=google.visualization.arrayToDataTable([['Zeit','m3',{role:'style'}],
m30=int(((hours*60)+mins)/30)+1
for tmp 1 48 1
wcs [
if (tmp%4==1)
then
wcs '%int((tmp-1)/2)%h'
else
wcs ''
endif
wcs ,%g30[tmp]%,
if (tmp<m30)
then
wcs 'green'],
endif
if (tmp==m30)
then
wcs 'red'],
endif
if (tmp>m30)
then
wcs 'blue'],
endif
next
wcs ]);
wcs var chart=new google.visualization.ColumnChart(document.getElementById('chart30'));
else
wcs var data=google.visualization.arrayToDataTable([['Zeit','m3'],
for tmp 1 48 1
wcs [
if (tmp%4==1)
then
wcs '%int((tmp-1)/2)%h'
else
wcs ''
endif
wcs ,%g30[tmp]%],
next
wcs ]);
wcs var chart=new google.visualization.AreaChart(document.getElementById('chart30'));
endif
wcs var options={chartArea:{left:40,width:'86%%'},legend:'none',title:'Tagesverlauf (30 min)',vAxis:{format:'#0.00 m3'},colors:['#2196F3'],areaOpacity:0.2};
wcs chart.draw(data,options);}google.charts.setOnLoadCallback(draw30);</script>
endif

#daysub
if wm>0
then
wcs <div id="day" style="width:400px;"></div>
wcs <script language="JavaScript">function drawChartD(){
if (chart_type_day==0)
then
wcs var data=google.visualization.arrayToDataTable([['Tag','m3',{role: 'style'}],
for tmp 1 dcon[-1] 1
wcs [%tmp%,%dcon[tmp]%,
if (tmp<day)
then
wcs 'green'],
endif
if (tmp==day)
then
wcs 'red'],
endif
if (tmp>day)
then
wcs 'blue'],
endif
next
wcs ]);
wcs var chart=new google.visualization.ColumnChart(document.getElementById('day'));
else
wcs var data=google.visualization.arrayToDataTable([['Tag','m3'],
for tmp 1 dcon[-1] 1
wcs [%tmp%,%dcon[tmp]%],
next
wcs ]);
wcs var chart=new google.visualization.AreaChart(document.getElementById('day'));
endif
wcs var options={chartArea:{left:40,width:'86%%'},legend:'none',title:'Tagesverbräuche (Monat %is[month]%)',vAxis:{format:'# m3'},colors:['#4CAF50'],areaOpacity:0.2};
wcs chart.draw(data,options);}google.charts.setOnLoadCallback(drawChartD);</script>
endif

#monthsub
if wm>0
then
wcs <div id="month" style="width:400px;"></div>
wcs <script language="JavaScript">function drawChartM(){
if (chart_type_month==0)
then
wcs var data=google.visualization.arrayToDataTable([['Monat','m3',{role: 'style'}],
for tmp 1 12 1
wcs ['%is[tmp]%',%mcon[tmp]%,
if (tmp<month)
then
wcs 'green'],
endif
if (tmp==month)
then
wcs 'red'],
endif
if (tmp>month)
then
wcs 'blue'],
endif
next
wcs ]);
wcs var chart=new google.visualization.ColumnChart(document.getElementById('month'));
else
wcs var data=google.visualization.arrayToDataTable([['Monat','m3'],
for tmp 1 12 1
wcs ['%is[tmp]%',%mcon[tmp]%],
next
wcs ]);
wcs var chart=new google.visualization.AreaChart(document.getElementById('month'));
endif
wcs var options={chartArea:{left:40,width:'86%%'},legend:'none',title:'Verbräuche (Jahr %0year%)',vAxis:{format:'# m3'},colors:['#FF9800'],areaOpacity:0.2};
wcs chart.draw(data,options);}google.charts.setOnLoadCallback(drawChartM);</script>
endif

>M 1
+1,14,c,1,-500,Gas
; Der Treiber liefert nur noch rohe Impulse an sml[1]
1,1-0:1.8.0*255(1,Impulse,count,total,0)

>S
if (res==1)
then
res=0
GasTotal=zaehler_start
dval=GasTotal
mval=GasTotal
yval=GasTotal
avg_g=0
for tmp 1 31 1 | dcon[tmp]=0 | next
for tmp 1 12 1 | mcon[tmp]=0 | next
for tmp 1 48 1 | g30[tmp]=0 | next
svars
endif

if (save==1)
then
save=0
svars
endif

if (year<2020)
then
break
endif

; --- DER SCHUTZ-MECHANISMUS ---
; Prüft den ersten Buchstaben von nm (w = ASCII 119)
if (sp(nm 1)==119)
then
v_mod=1
else
v_mod=0
endif

; GasBerechnung: Nur wenn v_mod auf 1 steht, wird addiert
if (v_mod==1)
then
; Wir berechnen den Stand: Startwert + (Impulse / factor)
GasTotal=zaehler_start+(sml[1]/factor)
endif

if (upsecs%10==0)
then
avg_g+=GasTotal-last_gas
last_gas=GasTotal
endif

if (upsecs%60==0)
then
hour=hours
yr=year
utm=s(2.0(int(uptime/1440)))+"d "+s(2.0(int(uptime/60)%24))+"h "+s(2.0(uptime%60))+"m"
dcon[day]=GasTotal-dval
mcon[month]=GasTotal-mval
m30=int(((hours*60)+mins)/30)+1
g30[m30]+=avg_g
avg_g=0

if ((chg[hour]>0) and (hour==0))
then
for tmp 1 48 1 | g30[tmp]=0 | next
if (day>1)
then
da=day
else
for tmp (da+1) 31 1 | dcon[tmp]=0 | next
mval=GasTotal
endif
if (day==1 and month==1)
then
yval=GasTotal
endif
dval=GasTotal
svars
endif
endif

>W
bu(save "Gespeichert" "Daten speichern")
bu(res "Reset läuft..." "Verbrauch zurücksetzen")

Zählerstand: {m} %3GasTotal% m³
Tagesverbrauch: {m} %2(GasTotal-dval)% m³
Monatsverbrauch: {m} %2(GasTotal-mval)% m³
Jahresverbrauch: {m} %2(GasTotal-yval)% m³

Datum: {m} %s(2.0day)%.%s(2.0month)%.%s(2.0year)% - %s(2.0hours)%:%s(2.0mins)%:%s(2.0secs)%
Uptime: {m} %utm%

$<div style="margin-left:-20px">
$<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
$<script type="text/javascript">google.charts.load('current',{packages:['corechart']});</script>

%=#30min
%=#daysub
%=#monthsub

$<center><span style="font-size:10px;color:#888;">
$Original von ottelo.jimdo.de - modifiziert von %nm%
$</span></center></div>
