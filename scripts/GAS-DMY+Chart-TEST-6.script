>D 48
factor=100
zaehler_start=3685565
res=0
save=0
tmp=0
hour=0
yr=0
da=1
GasTotal=0
utm=""
M:p:dcon=0 31
M:p:mcon=0 12
p:mval=0
p:dval=0
p:yval=0
M:p:sday=0 288
M:p:g30=0 48
m5=0
m30=0
cstr=""
avgv2=0
avgvc2=0
avg_g=0
last_gas=0

>B
=>sensor53 r
is(0 "Jan|Feb|Mär|Apr|Mai|Jun|Jul|Aug|Sep|Okt|Nov|Dez|")
=>sensor53 c1 %zaehler_start%
GasTotal=sml[1]
last_gas=sml[1]

#draw
wcs <div id="%1%" style="width:400px"></div><script>
wcs function dr%1%(){var d=google.visualization.arrayToDataTable([['','m3',{role:'style'}],
for tmp 1 %2% 1
wcs ['%tmp%',%3%[tmp],(tmp<%4%?'green':(tmp==%4%?'red':'blue'))],
next
wcs ]);new google.visualization.ColumnChart(document.getElementById('%1%')).draw(d,{chartArea:{left:40,width:'85%%'},legend:'none',title:'%5%'});}
wcs google.charts.setOnLoadCallback(dr%1%);</script>

>M 1
+1,14,c,1,-500,Gas
1,1-0:1.8.0*255(@%factor%,Gesamtverbrauch,m3,Total_In,2)

>S
if (res==1) {
res=0
GasTotal=sml[1]
dval=mval=yval=last_gas=GasTotal
for tmp 1 31 1 | dcon[tmp]=0 | next
for tmp 1 12 1 | mcon[tmp]=0 | next
for tmp 1 48 1 | g30[tmp]=0 | next
for tmp 0 288 1 | sday[tmp]=0 | next
svars
}
if (year>2020) {
if (upsecs%10==0) {
avg_g+=sml[1]-last_gas
last_gas=sml[1]
}
if (upsecs%60==0) {
utm=s(2.0(int(uptime/1440)))+"d "+s(2.0(int(uptime/60)%24))+"h"
GasTotal=sml[1]
dcon[day]=GasTotal-dval
mcon[month]=GasTotal-mval
m30=int(((hours*60)+mins)/30)+1
g30[m30]+=avg_g
avg_g=0
m5=int((((hours*60)+mins)/5)+1)
sday[m5]=GasTotal-dval
if (hour==0) {
for tmp 2 48 1 | g30[tmp]=0 | next
dval=GasTotal
svars
}
}
}

>W
bu(res "Reset" "Reset")
Tagesverbrauch: <b>%2(GasTotal-dval)% m3</b>
$<script src="https://www.gstatic.com/charts/loader.js"></script>
$<script>google.charts.load('current',{packages:['corechart']});</script>
; Diagramm 30 Min
%=#draw c30 48 g30 m30 "30 Min (24h)"
; Diagramm Tage
%=#draw cda 31 dcon day "Tage (Monat)"
; Diagramm Monate
%=#draw cmo 12 mcon month "Monate (Jahr)"
